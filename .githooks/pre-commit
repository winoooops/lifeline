#!/usr/bin/env bash
# Lifeline verifier — refuses any commit that re-introduces harness-plugin
# references into the plugin tree. Some files are exempted because the
# old names appear there for legitimate reasons:
#   - README.md, CHANGELOG.md  — document the harness → lifeline migration
#   - .gitignore               — keeps ignoring the legacy artifact dir so
#                                migrating users don't accidentally commit it
#   - *.jsonl                  — captured Claude CLI session fixtures used
#                                as test data; embedded plugin metadata is
#                                machine-recorded history, not source we control
#
# Patterns checked (specific, not the bare word "harness"):
#   \bharness-plugin\b       — plugin name in cache paths, slash refs
#   plugins/harness/         — old in-tree source path
#   \.harness-github-review  — old artifact directory
#   /harness-                — slash-command prefixes (/harness-plugin:, /harness-loop, etc.)
#
# To bypass for a one-off legitimate reason: git commit --no-verify
# (and add a justification in the commit body).

set -euo pipefail

if hits=$(grep -rnE \
  --exclude=README.md --exclude=CHANGELOG.md --exclude=.gitignore \
  --exclude='*.jsonl' \
  --exclude-dir=.git --exclude-dir=.githooks \
  --exclude-dir=__pycache__ --exclude-dir=.pytest_cache --exclude-dir=.venv \
  '(\bharness-plugin\b|plugins/harness/|\.harness-github-review\b|/harness-)' .); then
  echo "ERROR: lifeline verifier found harness-plugin references:" >&2
  echo "$hits" | sed 's/^/  /' >&2
  echo "" >&2
  echo "Either rewrite the references or, if intentional, commit with --no-verify" >&2
  echo "and justify in the body." >&2
  exit 1
fi
